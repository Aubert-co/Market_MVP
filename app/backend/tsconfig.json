{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "outDir": "./dist",
    "rootDir": "./src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "baseUrl": ".",
    "paths": {
      "@/*":["src/*"],
      "@/modules":["src/modules/*"],
      "@/tests":["src/tests/*"]
    },
    "typeRoots": ["./node_modules/@types", "./src/types"]

  },
  "include": ["src/**/*", "public"],
  "exclude": ["node_modules","src/test-load"]
}